inventory_hostname,ansible_host,distribution,distribution_version,kernel,chapter,cis_control_id,cis_control_title,status,status_mark,normalized_status,implementation_class,has_audit_evidence
{% for host_artifact in (cis_report_host_artifacts | default([])) %}{% for chapter in (host_artifact.chapters | default([])) %}{% for control in (chapter.controls | default([])) %}"{{ host_artifact.metadata.host.inventory_hostname | replace('"', '""') }}","{{ host_artifact.metadata.host.ansible_host | replace('"', '""') }}","{{ host_artifact.metadata.host.distribution | replace('"', '""') }}","{{ host_artifact.metadata.host.distribution_version | replace('"', '""') }}","{{ host_artifact.metadata.host.kernel | replace('"', '""') }}","{{ chapter.chapter | replace('"', '""') }}","{{ control.cis_control_id | replace('"', '""') }}","{{ control.cis_control_title | replace('"', '""') }}","{{ control.status | replace('"', '""') }}","{{ control.status_mark | replace('"', '""') }}","{{ control.normalized_status | replace('"', '""') }}","{{ control.implementation_class | replace('"', '""') }}",{{ 'true' if control.has_audit_evidence else 'false' }}
{% endfor %}{% endfor %}{% endfor %}
